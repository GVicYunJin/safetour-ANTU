<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/mica_light_surface" />
                    <stroke
                        android:width="2dp"
                        android:color="@color/win_blue" />
                    <corners android:radius="8dp" />
                    <padding
                        android:left="16dp"
                        android:top="14dp"
                        android:right="16dp"
                        android:bottom="14dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/mica_light_surface" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/acrylic_light_border" />
                    <corners android:radius="8dp" />
                    <padding
                        android:left="16dp"
                        android:top="14dp"
                        android:right="16dp"
                        android:bottom="14dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>