<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#1a1a1a"
    android:gravity="center">

    <!-- 内容容器 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:maxWidth="700dp"
        android:minWidth="300dp">

        <!-- ========== 第一个界面：EULA协议 ========== -->
        <LinearLayout
            android:id="@+id/eula_first_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 标题 -->
            <TextView
                android:id="@+id/eula_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SafeTour（安途）终端用户许可协议"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:paddingBottom="20dp"
                android:layout_gravity="center"/>

            <!-- 协议内容滚动区域 -->
            <ScrollView
                android:id="@+id/eula_scroll"
                android:layout_width="wrap_content"
                android:layout_height="400dp"
                android:background="#2a2a2a"
                android:padding="20dp"
                android:scrollbarStyle="insideOverlay"
                android:layout_marginBottom="16dp"
                android:minWidth="300dp" 
                android:maxWidth="650dp">

                <TextView
                    android:id="@+id/eula_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#e0e0e0"
                    android:textSize="15sp"
                    android:lineSpacingMultiplier="1.5"/>
            </ScrollView>

            <!-- 底部操作区域 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical" 
                android:minWidth="300dp">

                <!-- 复选框 -->
                <CheckBox
                    android:id="@+id/eula_checkbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#4CAF50"
                    android:textSize="15sp"
                    android:textColor="#e0e0e0"/>

                <!-- 协议文字 -->
                <TextView
                    android:id="@+id/eula_checkbox_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="我已阅读并同意本《SafeTour（安途）终端用户许可协议》"
                    android:textSize="15sp"
                    android:textColor="#e0e0e0"
                    android:paddingLeft="12dp"
                    android:maxWidth="400dp" 
                    android:layout_weight="1"/>

                <!-- 进入按钮 -->
                <Button
                    android:id="@+id/eula_enter_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="进入"
                    android:textSize="18sp"
                    android:textColor="#ffffff"
                    android:background="@drawable/rounded_button_primary"
                    android:enabled="false"
                    android:paddingLeft="32dp"
                    android:paddingRight="32dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:layout_marginLeft="16dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ========== 第二个界面：隐私警告 ========== -->
        <LinearLayout
            android:id="@+id/eula_second_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- 警告图标 -->
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@android:drawable/ic_dialog_alert"
                android:tint="#FF9800"
                android:layout_gravity="center"
                android:paddingBottom="16dp"/>

            <!-- 警告标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="重要提醒"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FF9800"
                android:paddingBottom="16dp"
                android:layout_gravity="center"/>

            <!-- 警告内容滚动区域 -->
            <ScrollView
                android:layout_width="wrap_content"
                android:layout_height="400dp"
                android:background="#2a2a2a"
                android:padding="20dp"
                android:scrollbarStyle="insideOverlay"
                android:layout_marginBottom="16dp"
                android:minWidth="300dp" 
                android:maxWidth="650dp">

                <TextView
                    android:id="@+id/eula_warning_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#e0e0e0"
                    android:textSize="15sp"
                    android:lineSpacingMultiplier="1.5"/>
            </ScrollView>

            <!-- 倒计时提示 -->
            <TextView
                android:id="@+id/countdown_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="请仔细阅读，5秒后可继续"
                android:textSize="14sp"
                android:textColor="#9E9E9E"
                android:layout_gravity="center"
                android:paddingBottom="12dp"/>

            <!-- 下一步按钮 -->
            <Button
                android:id="@+id/eula_next_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="下一步"
                android:textSize="18sp"
                android:textColor="#ffffff"
                android:background="@drawable/rounded_button_primary"
                android:enabled="false"
                android:paddingLeft="48dp"
                android:paddingRight="48dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_gravity="center"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>