<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/mica_light_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 返回按钮 -->
        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="返回"
            android:background="@drawable/rounded_button_back"
            android:textColor="@color/text_primary_light"
            android:layout_marginBottom="24dp"
            android:elevation="0dp"
            android:stateListAnimator="@null"/>

        <!-- 自动上传模块 - 卡片样式 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp"
            android:padding="20dp"
            android:background="@drawable/acrylic_card_bg"
            android:elevation="0dp"
            android:clipToOutline="true"
            android:outlineProvider="background">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="自动上传"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary_light"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="开启后将自动上传数据和照片"
                    android:textSize="12sp"
                    android:textColor="@color/text_tertiary_light"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
            <Switch
                android:id="@+id/switch_auto_upload"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:layout_marginEnd="12dp"/>
            <View
                android:id="@+id/status_indicator_settings"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/indicator_circle" />
        </LinearLayout>

        <!-- 上次上传时间 -->
        <TextView
            android:id="@+id/tv_last_upload_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="上次上传时间: 从未"
                android:textSize="13sp"
                android:textColor="@color/text_secondary_light"
                android:layout_marginBottom="24dp"
                android:paddingStart="4dp"/>

        <!-- API 配置卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/acrylic_card_bg"
            android:elevation="0dp"
            android:clipToOutline="true"
            android:outlineProvider="background"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="服务器配置"
                android:textSize="15sp"
                android:textColor="@color/text_primary_light"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- Data API 输入框 -->
            <EditText
                android:id="@+id/et_data_api"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Data API (URL)"
                android:textColor="@color/text_primary_light"
                android:textColorHint="@color/text_tertiary_light"
                android:inputType="textUri"
                android:background="@drawable/rounded_edittext"
                android:layout_marginBottom="12dp"
                android:elevation="0dp"
                android:stateListAnimator="@null"/>

            <!-- Photo API 输入框 -->
            <EditText
                android:id="@+id/et_photo_api"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Photo API (URL)"
                android:textColor="@color/text_primary_light"
                android:textColorHint="@color/text_tertiary_light"
                android:inputType="textUri"
                android:background="@drawable/rounded_edittext"
                android:layout_marginBottom="12dp"
                android:elevation="0dp"
                android:stateListAnimator="@null"/>

            <!-- UUID 输入框 -->
            <EditText
                android:id="@+id/et_uuid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="UUID (字符串)"
                android:textColor="@color/text_primary_light"
                android:textColorHint="@color/text_tertiary_light"
                android:inputType="text"
                android:background="@drawable/rounded_edittext"
                android:elevation="0dp"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- 按钮行：左侧尝试获取，右侧手动上传 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <!-- 左侧：尝试获取按钮 -->
            <Button
                android:id="@+id/btn_try_get"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="尝试获取"
                android:background="@drawable/rounded_button"
                android:textColor="@color/text_primary_light"
                android:padding="16dp"
                android:layout_marginEnd="12dp"
                android:elevation="0dp"
                android:stateListAnimator="@null"/>

            <!-- 右侧：手动上传按钮 - 主按钮样式 -->
            <Button
                android:id="@+id/btn_upload"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="手动上传"
                android:background="@drawable/rounded_button_primary"
                android:textColor="@color/white"
                android:padding="16dp"
                android:layout_marginStart="12dp"
                android:elevation="0dp"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <!-- 预览卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/mica_light_surface"
            android:elevation="0dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/mica_light_surface"
            app:cardElevation="0dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_preview_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="设备信息预览"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:textColor="@color/text_primary_light"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/acrylic_light_border"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tv_json_preview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="JSON 预览: --"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary_light"
                    android:singleLine="false"
                    android:maxLines="15"
                    android:scrollbars="vertical"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 隐私警告区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@color/warning_light"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="16dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️ 重要提醒"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/danger"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tv_warning_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/danger"
                android:lineSpacingMultiplier="1.4"
                android:text="尊敬的用户您好：\n\n本项目开源免费，如果你有偿获得，请收集凭证并提交给我们2582634359@qq.com，我们会依法追究责任\n开源仓库地址：https://github.com/GVicYunJin/safetour-ANTU\n\n重要内容请知悉：\n在您授予完整权限、填写 API 地址与 UUID 参数后，本设备授权的数据将实时对该私有服务器所有者完全公开：\n对方可以全天候查看你的实时位置、历史行程轨迹、设备电量、WiFi、基站、传感器状态等全部设备数据。\n仅你手动点击拍摄的前后置照片会直接上传至对方服务器，对方可无条件随时查看。\n你的报备照片与部分设备数据，可能自动推送至对方配置的 QQ 群聊中实时公开展示。\n本项目无任何官方中转服务器、官方数据服务。\n你填写的服务器地址完全为第三方私有自建服务，所有数据风险由你自行承担。\n若你不了解本项目的工作原理，不知道这个软件有什么用，会做什么，请立即前往原作者短视频平台主页查看。\n请确定你完全知悉、明白这个软件会做什么，完全信任给你接口的人的情况下使用\n如果有不法分子尝试通过该开源项目追踪并获取你的隐私数据，请收集凭证并提交给我们，我们会依法追究责任\n\nbilibili：https://b23.tv/SLUO74J，抖音：https://v.douyin.com/mbhXkGhxHoA/"/>
        </LinearLayout>

        <!-- 显示协议按钮 -->
        <Button
            android:id="@+id/btn_show_eula"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="查看用户协议"
            android:background="@drawable/rounded_button"
            android:textColor="@color/text_primary_light"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="0dp"
            android:stateListAnimator="@null"/>

        <!-- EULA协议内容区域 -->
        <LinearLayout
            android:id="@+id/layout_eula_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/acrylic_card_bg"
            android:visibility="gone"
            android:layout_marginBottom="24dp"
            android:descendantFocusability="blocksDescendants">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📄 用户协议"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary_light"
                android:layout_marginBottom="12dp"/>

            <com.example.tt.InnerScrollView
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:scrollbars="vertical"
                android:focusable="true"
                android:focusableInTouchMode="true">
                <TextView
                    android:id="@+id/tv_eula_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary_light"
                    android:lineSpacingMultiplier="1.5"
                    android:paddingBottom="16dp"/>
            </com.example.tt.InnerScrollView>
        </LinearLayout>

    </LinearLayout>
</ScrollView>