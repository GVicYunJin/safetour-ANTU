<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/win_blue_pressed" />
                    <corners android:radius="8dp" />
                    <padding
                        android:left="16dp"
                        android:top="12dp"
                        android:right="16dp"
                        android:bottom="12dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_hovered="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/win_blue_hover" />
                    <corners android:radius="8dp" />
                    <padding
                        android:left="16dp"
                        android:top="12dp"
                        android:right="16dp"
                        android:bottom="12dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/win_blue" />
                    <corners android:radius="8dp" />
                    <padding
                        android:left="16dp"
                        android:top="12dp"
                        android:right="16dp"
                        android:bottom="12dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>